{
  "overrides": [
    {
      "files": ["*.css", "*.scss"],
      "options": {
        "singleQuote": true
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "options": {
        "printWidth": 120,
        "tabWidth": 2,
        "semi": false,
        "singleQuote": true,
        "jsxSingleQuote": true
      }
    }
  ]
}
